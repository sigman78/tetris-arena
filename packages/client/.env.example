# Override the server address when client and server run on different machines.
# Without these, the client auto-derives the server host from window.location.hostname
# (works when both run on the same machine, accessed via its LAN IP).
#
# Uncomment and set if your Vite dev server is on a different box than Colyseus:
# VITE_SERVER_HTTP_URL=http://192.168.1.199:2567
# VITE_SERVER_WS_URL=ws://192.168.1.199:2567
