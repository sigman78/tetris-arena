DATABASE_URL="file:./dev.db"
PORT=2567
# Bind address — use 0.0.0.0 to listen on all interfaces (required for LAN access)
BIND_HOST=0.0.0.0
# Allowed client origins. Use * to permit all (convenient for LAN play).
# For production list origins explicitly: http://192.168.1.10:5173,http://192.168.1.11:5173
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
